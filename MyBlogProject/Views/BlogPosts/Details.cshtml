@model MyBlogProject.Models.BlogPost
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <article class="p-5 bg-white shadow-lg rounded-4 border-0">
                <header class="mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-primary px-3 py-2 rounded-pill">Teknoloji Makalesi</span>
                        <small class="text-muted">
                            <i class="far fa-calendar-alt me-1"></i> @Model.CreatedDate.ToString("dd MMMM yyyy")
                        </small>
                    </div>
                    <h1 class="display-5 fw-bold text-dark">@Model.Title</h1>
                    <hr class="my-4 text-primary opacity-25">

                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="text-center mb-4">
                         
                            <img src="@Model.ImagePath"
                                 class="img-fluid rounded-4 shadow-sm border"
                                 style="max-height: 450px; width: 100%; object-fit: cover;"
                                 alt="@Model.Title"
                                 onerror="this.style.display='none'; document.getElementById('img-error').style.display='block';" />

                            <div id="img-error" class="alert alert-danger mt-2" style="display:none;">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <strong>Resim Yüklenemedi!</strong> <br />
                                Veritabanındaki yol: <code>@Model.ImagePath</code> <br />
                                <small>Lütfen wwwroot/img klasöründe bu dosyanın olduğundan emin olun.</small>
                            </div>
                        </div>
                    }
                </header>

                <section class="mb-5 fs-5 text-secondary" style="white-space: pre-wrap; line-height: 1.8; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
                    @Model.Content
                </section>

                <footer class="border-top pt-4 mt-5 d-flex justify-content-between align-items-center">
                    <div>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-left me-2"></i>Listeye Dön
                        </a>
                    </div>

                    @if (Context.Session.GetString("UserRole") != null)
                    {
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning rounded-pill px-4 fw-bold text-dark">
                                <i class="fas fa-edit me-1"></i>Düzenle
                            </a>

                            @if (Context.Session.GetString("UserRole") == "Admin")
                            {
                                <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger rounded-pill px-4 fw-bold">
                                    <i class="fas fa-trash me-1"></i>Sil
                                </a>
                            }
                        </div>
                    }
                </footer>
            </article>
        </div>
    </div>
</div>