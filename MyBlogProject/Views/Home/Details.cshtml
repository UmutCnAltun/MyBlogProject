@model MyBlogProject.Models.BlogPost

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <article>
                <h1 class="display-4 fw-bold">@Model.Title</h1>
                <p class="text-muted">
                    <i class="bi bi-calendar"></i> @Model.CreatedDate.ToString("dd MMMM yyyy")
                </p>
                <hr />
                <div class="blog-content fs-5" style="white-space: pre-wrap; line-height: 1.8;">
                    @Model.Content
                </div>
            </article>

            <div class="mt-5 border-top pt-3">
                <a href="/Home/Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>