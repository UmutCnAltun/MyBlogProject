@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyBlogProject</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/MyBlogProject.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
</head>

<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-code me-2 text-primary"></i>MyBlogProject
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="mainNavbar">

                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Ana Sayfa
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Aboutme">
                                Hakkımda
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link fw-semibold"
                               asp-controller="BlogPosts"
                               asp-action="Index">
                                <i class="fa-solid fa-newspaper me-1"></i>Yazılarım
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index"
                               asp-fragment="contact">
                                Bana Ulaş
                            </a>
                        </li>

                    </ul>

                    <ul class="navbar-nav">

                        @if (Context.Session.GetString("UserRole") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning"
                                   asp-controller="Admin"
                                   asp-action="Index">
                                    <i class="fa-solid fa-user-gear me-1"></i>Panel
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold"
                                   asp-controller="Account"
                                   asp-action="Logout">
                                    <i class="fa-solid fa-right-from-bracket me-1"></i>Çıkış Yap
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    <i class="fa-solid fa-user me-1"></i>Giriş Yap
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <main class="flex-fill">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top bg-light mt-auto">
        <div class="container text-center py-3">
            &copy; 2026 - <span class="fw-bold">MyBlogProject</span> -
            <a asp-controller="Home"
               asp-action="Privacy"
               class="text-decoration-none">
                Gizlilik Politikası
            </a>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>