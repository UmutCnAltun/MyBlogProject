@model IEnumerable<MyBlogProject.Models.BlogPost>

<section id="admin-dashboard" class="container mt-4">
    <h1>Blog Yönetim Paneli</h1>
    <p>Hoş geldin Umut Can. Buradan içeriklerini yönetebilirsin.</p>

    <div id="stats" style="display: flex; gap: 20px; margin-bottom: 20px;">
        <div style="border: 1px solid #ddd; padding: 15px; border-radius: 8px; background-color: #f8f9fa;">
            <p class="mb-1">Toplam Yazı Sayısı</p>
            <h2 class="text-primary">@Model.Count()</h2>
        </div>
        <div style="border: 1px solid #ddd; padding: 15px; border-radius: 8px; background-color: #f8f9fa;"> 
            <p class="mb-1">Toplam Mesaj</p>
            <h2 class="text-success">3</h2>
        </div>
    </div>

    <hr>

    <nav id="admin-nav" class="mb-4">
        <ul style="list-style: none; display: flex; gap: 15px; padding: 0; flex-wrap: wrap;">
            <li><a asp-action="Create" class="btn btn-success">Yeni Yazı Ekle</a></li>
            <li><a asp-action="Messages" class="btn btn-info text-white shadow-sm">Gelen Mesajlar</a></li>
            <li><a href="/Home/Index" class="btn btn-secondary">Siteye Geri Dön</a></li>
            <li><a asp-controller="Account" asp-action="Logout" class="btn btn-danger">Güvenli Çıkış Yap</a></li>
        </ul>
    </nav>

    <div id="manage-posts">
        <h3>Mevcut Blog Yazıları</h3>
        <table class="table table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Başlık</th>
                    <th>Tarih</th>
                    <th style="width: 200px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.CreatedDate.ToShortDateString()</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning fw-bold">Düzenle</a>
                                <form asp-action="DeletePost" method="post" onsubmit="return confirm('Bu yazıyı silmek istediğinize emin misiniz?');" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>