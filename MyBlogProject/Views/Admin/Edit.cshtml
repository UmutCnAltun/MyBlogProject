@model MyBlogProject.Models.BlogPost

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h2 class="mb-0">Yazıyı Düzenle</h2>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Yazı Başlığı</label>
                    <input asp-for="Title" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">İçerik</label>
                    <textarea asp-for="Content" class="form-control" rows="10" required></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
                    <a asp-action="Index" class="btn btn-secondary">İptal Et</a>
                </div>
            </form>
        </div>
    </div>
</div>