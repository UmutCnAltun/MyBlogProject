@model IEnumerable<MyBlogProject.Models.ContactMessage>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-envelope-fill"></i> Gelen Mesajlar</h2>
        <a href="/Admin/Index" class="btn btn-secondary btn-sm">Panele Dön</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Gönderen</th>
                        <th>E-posta</th>
                        <th>Konu</th>
                        <th>Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var message in Model)
                    {
                        <tr>
                            <td class="fw-bold">@message.Name</td>
                            <td>@message.Email</td>
                            <td>@message.Subject</td>
                            <td>@message.SentDate.ToString("g")</td>
                            <td>
                                <div class="d-flex gap-2">

                                    <button class="btn btn-primary btn-sm" onclick="alert('@message.Message')">Oku</button>

                                    <form asp-action="DeleteMessage" method="post" onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">
                                        <input type="hidden" name="id" value="@message.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>