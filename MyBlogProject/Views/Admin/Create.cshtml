@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model MyBlogProject.Models.BlogPost

<div class="container mt-4">
    <h2>Yeni Blog Yazısı Oluştur</h2>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Yazı Başlığı</label>
                    <input asp-for="Title" class="form-control" placeholder="Başlık giriniz..." required />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">Kapak Fotoğrafı</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    <small class="text-muted">Bir görsel seçerseniz yazının başında görünecektir.</small>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold">İçerik</label>
                    <textarea asp-for="Content" class="form-control" rows="10" placeholder="Blog yazınızı buraya yazın..." required></textarea>
                </div>

                <input type="hidden" asp-for="CreatedDate" value="@DateTime.Now" />

                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary">Yayınla</button>
                    <a asp-action="Index" class="btn btn-secondary">İptal Et</a>
                </div>
            </form>
        </div>
    </div>
</div>